{
  "permissions": {
    "deny": [
      "Read(./**/*.pem)",
      "Read(./**/*-key.json)",
      "Read(./**/service-account*.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ],
    "ask": [
      "Bash(gcloud * delete*)",
      "Bash(bq rm*)",
      "Bash(gsutil rm*)",
      "Bash(terraform destroy*)",
      "Bash(gcloud * deploy*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-coauthor.sh",
            "args": [],
            "if": "Bash(git commit *)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/protect-main.sh",
            "args": [],
            "if": "Bash(git push *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/no-secrets.sh",
            "args": []
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-python.sh",
            "args": [],
            "if": "Edit(*.py)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-python.sh",
            "args": [],
            "if": "Write(*.py)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/md-guard.sh",
            "args": [],
            "if": "Edit(*.md)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/md-guard.sh",
            "args": [],
            "if": "Write(*.md)"
          }
        ]
      }
    ],
    "Stop": []
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "//": "Project-scope settings. Hooks here are the enforced guardrails. Permissions below are the soft rails."
}
